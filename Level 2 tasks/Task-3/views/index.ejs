<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Registration Portal</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">

            <a class="navbar-brand" href="#">Student Portal</a>

            <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav">

                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">
                        <a class="nav-link" href="#about">About</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#services">Services</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#contact">Contact</a>
                    </li>

                </ul>

            </div>

        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">

        <div class="container text-center">

            <h1>Welcome to Student Registration Portal</h1>

            <p>
                Register, Learn and Grow with Us
            </p>

            <a href="#contact" class="btn btn-custom">
                Get Started
            </a>

        </div>

    </section>

    <!-- About Section -->
    <section id="about" class="about-section">

        <div class="container text-center">

            <h2 class="section-title">
                About Us
            </h2>

            <p class="about-text">

                We help students improve their skills through
                technology, innovation, internships, projects,
                and career-focused learning experiences.

            </p>

        </div>

    </section>

    <!-- Services Section -->
    <section id="services" class="services-section">

        <div class="container">

            <h2 class="section-title text-center">
                Our Services
            </h2>

            <div class="row g-4 mt-4">

                <div class="col-md-4">

                    <div class="card service-card">

                        <div class="card-body text-center">

                            <h4>📚 Courses</h4>

                            <p>
                                Learn industry-relevant skills and stay ahead.
                            </p>

                        </div>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="card service-card">

                        <div class="card-body text-center">

                            <h4>💻 Projects</h4>

                            <p>
                                Build real-world projects and strengthen your portfolio.
                            </p>

                        </div>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="card service-card">

                        <div class="card-body text-center">

                            <h4>🚀 Internships</h4>

                            <p>
                                Gain practical experience and grow professionally.
                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact-section">

        <div class="container">

            <h2 class="section-title text-center">
                Contact Us
            </h2>

            <form class="contact-form">

                <input
                    type="text"
                    class="form-control"
                    placeholder="Enter Name"
                    required
                >

                <input
                    type="email"
                    class="form-control"
                    placeholder="Enter Email"
                    required
                >

                <textarea
                    class="form-control"
                    rows="5"
                    placeholder="Enter Message"
                    required
                ></textarea>

                <button class="btn btn-custom w-100">
                    Send Message
                </button>

            </form>

        </div>

    </section>

    <!-- Footer -->
    <footer>

        <p>
            © 2026 Student Registration Portal | All Rights Reserved
        </p>

    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>